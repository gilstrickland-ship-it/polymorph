{
  "name": "@polymorph/native-parity",
  "version": "0.0.0",
  "description": "Parses every adapter (Web CSS vars + Dart / Swift / Kotlin) back into a normalized form and asserts cross-adapter parity against the core resolved theme.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@polymorph/spec": "workspace:*",
    "@polymorph/core": "workspace:*",
    "@polymorph/adapter-web": "workspace:*",
    "@polymorph/adapter-flutter": "workspace:*",
    "@polymorph/adapter-swift": "workspace:*",
    "@polymorph/adapter-kotlin": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gilstrickland-ship-it/polymorph.git",
    "directory": "packages/native-parity"
  },
  "homepage": "https://github.com/gilstrickland-ship-it/polymorph#readme",
  "bugs": {
    "url": "https://github.com/gilstrickland-ship-it/polymorph/issues"
  }
}
