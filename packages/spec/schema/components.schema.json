    "input": {
      "type": "object",
      "properties": {
        "background": {
          "$ref": "https://polymorph.dev/schema/dtcg-types.schema.json#/$defs/color"
        },
        "border": {
          "$ref": "https://polymorph.dev/schema/dtcg-types.schema.json#/$defs/color"
        },
