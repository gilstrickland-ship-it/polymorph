{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polymorph.dev/schema/components.schema.json",
  "title": "Polymorph optional component-token overrides (closed v0 role set)",
  "$defs": {
    "button": {
      "type": "object",
      "properties": {
