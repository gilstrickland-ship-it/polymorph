    { "id": "pm.typography.heading", "type": "typography", "required": true, "modeSensitive": false, "group": "typography", "description": "Section/screen heading" },
    { "id": "pm.typography.headingSm", "type": "typography", "required": false, "modeSensitive": false, "group": "typography", "description": "Sub-heading" },
    { "id": "pm.typography.body", "type": "typography", "required": true, "modeSensitive": false, "group": "typography", "description": "Body copy / field text" },
    { "id": "pm.typography.bodyStrong", "type": "typography", "required": false, "modeSensitive": false, "group": "typography", "description": "Emphasized body" },
    { "id": "pm.typography.label", "type": "typography", "required": true, "modeSensitive": false, "group": "typography", "description": "Form labels / buttons" },
    { "id": "pm.typography.caption", "type": "typography", "required": true, "modeSensitive": false, "group": "typography", "description": "Helper/validation/disclosure text" },
    { "id": "pm.typography.mono", "type": "typography", "required": false, "modeSensitive": false, "group": "typography", "description": "Codes, account numbers" },

    { "id": "pm.space.none", "type": "dimension", "required": true, "modeSensitive": false, "group": "space", "description": "0" },
    { "id": "pm.space.xs", "type": "dimension", "required": true, "modeSensitive": false, "group": "space", "description": "Tightest gap" },
    { "id": "pm.space.sm", "type": "dimension", "required": true, "modeSensitive": false, "group": "space", "description": "Small gap" },
    { "id": "pm.space.md", "type": "dimension", "required": true, "modeSensitive": false, "group": "space", "description": "Default inset/gap" },
    { "id": "pm.space.lg", "type": "dimension", "required": true, "modeSensitive": false, "group": "space", "description": "Section spacing" },
    { "id": "pm.space.xl", "type": "dimension", "required": true, "modeSensitive": false, "group": "space", "description": "Large spacing" },
    { "id": "pm.space.2xl", "type": "dimension", "required": false, "modeSensitive": false, "group": "space", "description": "Extra-large spacing" },
    { "id": "pm.space.3xl", "type": "dimension", "required": false, "modeSensitive": false, "group": "space", "description": "Hero spacing" },

    { "id": "pm.radius.none", "type": "dimension", "required": true, "modeSensitive": false, "group": "radius", "description": "Square corners" },
    { "id": "pm.radius.control", "type": "dimension", "required": true, "modeSensitive": false, "group": "radius", "description": "Inputs, buttons" },
    { "id": "pm.radius.card", "type": "dimension", "required": true, "modeSensitive": false, "group": "radius", "description": "Cards/sheets" },
    { "id": "pm.radius.pill", "type": "dimension", "required": false, "modeSensitive": false, "group": "radius", "description": "Pills/badges" },
    { "id": "pm.radius.full", "type": "dimension", "required": false, "modeSensitive": false, "group": "radius", "description": "Circular" },

    { "id": "pm.border.width.hairline", "type": "dimension", "required": true, "modeSensitive": false, "group": "border.width", "description": "1px-equivalent divider" },
    { "id": "pm.border.width.thin", "type": "dimension", "required": true, "modeSensitive": false, "group": "border.width", "description": "Default control border" },
    { "id": "pm.border.width.thick", "type": "dimension", "required": false, "modeSensitive": false, "group": "border.width", "description": "Emphasis border" },

    { "id": "pm.elevation.flat", "type": "shadow", "required": true, "modeSensitive": true, "group": "elevation", "description": "No shadow" },
    { "id": "pm.elevation.raised", "type": "shadow", "required": true, "modeSensitive": true, "group": "elevation", "description": "Cards" },
    { "id": "pm.elevation.overlay", "type": "shadow", "required": false, "modeSensitive": true, "group": "elevation", "description": "Modals/popovers" },

    { "id": "pm.opacity.disabled", "type": "number", "required": true, "modeSensitive": false, "group": "opacity", "description": "Disabled element opacity" },
    { "id": "pm.opacity.muted", "type": "number", "required": false, "modeSensitive": false, "group": "opacity", "description": "De-emphasis" },
    { "id": "pm.opacity.scrim", "type": "number", "required": false, "modeSensitive": false, "group": "opacity", "description": "Backdrop scrim" },

    { "id": "pm.motion.duration.short", "type": "duration", "required": true, "modeSensitive": false, "group": "motion.duration", "description": "Micro-interactions" },
    { "id": "pm.motion.duration.base", "type": "duration", "required": true, "modeSensitive": false, "group": "motion.duration", "description": "Standard transitions" },
    { "id": "pm.motion.duration.long", "type": "duration", "required": false, "modeSensitive": false, "group": "motion.duration", "description": "Larger transitions" },
    { "id": "pm.motion.easing.standard", "type": "cubicBezier", "required": true, "modeSensitive": false, "group": "motion.easing", "description": "Default easing" },
    { "id": "pm.motion.easing.emphasized", "type": "cubicBezier", "required": false, "modeSensitive": false, "group": "motion.easing", "description": "Expressive easing" },
    { "id": "pm.motion.duration.reduced", "type": "duration", "required": true, "modeSensitive": false, "group": "motion.duration", "description": "Reduced-motion clamp — every motion duration collapses to this when prefers-reduced-motion is on" },
    { "id": "pm.motion.easing.reduced", "type": "cubicBezier", "required": false, "modeSensitive": false, "group": "motion.easing", "description": "Reduced-motion easing — defaults to linear when absent" },

    { "id": "pm.size.control.sm", "type": "dimension", "required": false, "modeSensitive": false, "group": "size.control", "description": "Compact control height" },
    { "id": "pm.size.control.md", "type": "dimension", "required": true, "modeSensitive": false, "group": "size.control", "description": "Default control height" },
    { "id": "pm.size.control.lg", "type": "dimension", "required": false, "modeSensitive": false, "group": "size.control", "description": "Large control height" },
    { "id": "pm.size.touchTarget.min", "type": "dimension", "required": true, "modeSensitive": false, "group": "size.touchTarget", "description": "Min touch target (a11y advisory)" },
    { "id": "pm.size.icon.md", "type": "dimension", "required": true, "modeSensitive": false, "group": "size.icon", "description": "Default icon size" }
  ],
  "componentRoles": [
    { "role": "button.primary", "properties": [
      { "property": "background", "defaultsFrom": "pm.color.action.primary.rest" },
      { "property": "foreground", "defaultsFrom": "pm.color.text.onAction" },
      { "property": "radius", "defaultsFrom": "pm.radius.control" }
    ] },
    { "role": "button.secondary", "properties": [
      { "property": "background", "defaultsFrom": "pm.color.action.secondary.rest" },
      { "property": "border", "defaultsFrom": "pm.color.action.secondary.rest" },
      { "property": "foreground", "defaultsFrom": "pm.color.text.body" }
    ] },
    { "role": "button.danger", "properties": [
      { "property": "background", "defaultsFrom": "pm.color.action.danger.rest" },
      { "property": "foreground", "defaultsFrom": "pm.color.text.onAction" }
    ] },
    { "role": "input", "properties": [
      { "property": "background", "defaultsFrom": "pm.color.surface.raised" },
      { "property": "border", "defaultsFrom": "pm.color.border.default" },
      { "property": "borderFocus", "defaultsFrom": "pm.color.border.focus" },
      { "property": "foreground", "defaultsFrom": "pm.color.text.body" },
      { "property": "radius", "defaultsFrom": "pm.radius.control" }
    ] },
    { "role": "card", "properties": [
      { "property": "background", "defaultsFrom": "pm.color.surface.raised" },
      { "property": "radius", "defaultsFrom": "pm.radius.card" },
      { "property": "elevation", "defaultsFrom": "pm.elevation.raised" }
    ] },
    { "role": "stepIndicator", "properties": [
      { "property": "activeColor", "defaultsFrom": "pm.color.action.primary.rest" },
      { "property": "inactiveColor", "defaultsFrom": "pm.color.border.default" }
    ] },
    { "role": "disclosure", "properties": [
      { "property": "foreground", "defaultsFrom": "pm.color.text.muted" },
      { "property": "typography", "defaultsFrom": "pm.typography.caption" }
    ] }
  ]
}
