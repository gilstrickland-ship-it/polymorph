    { "id": "pm.color.action.secondary.pressed", "type": "color", "required": false, "modeSensitive": true, "group": "color.action.secondary", "description": "Secondary pressed" },
    { "id": "pm.color.action.danger.rest", "type": "color", "required": true, "modeSensitive": true, "group": "color.action.danger", "description": "Destructive action fill" },
    { "id": "pm.color.action.danger.pressed", "type": "color", "required": false, "modeSensitive": true, "group": "color.action.danger", "description": "Destructive pressed" },

    { "id": "pm.color.feedback.success", "type": "color", "required": true, "modeSensitive": true, "group": "color.feedback", "description": "Success accent/text" },
    { "id": "pm.color.feedback.warning", "type": "color", "required": true, "modeSensitive": true, "group": "color.feedback", "description": "Warning accent/text" },
    { "id": "pm.color.feedback.error", "type": "color", "required": true, "modeSensitive": true, "group": "color.feedback", "description": "Error accent/text (validation)" },
    { "id": "pm.color.feedback.info", "type": "color", "required": false, "modeSensitive": true, "group": "color.feedback", "description": "Informational accent/text" },
    { "id": "pm.color.border.default", "type": "color", "required": true, "modeSensitive": true, "group": "color.border", "accessibility": "decorative", "description": "Default control/divider border — decorative; design systems commonly use a soft hairline (Primer's #d1d9e0 etc.) that sits below 3:1 by design" },
    { "id": "pm.color.border.subtle", "type": "color", "required": false, "modeSensitive": true, "group": "color.border", "accessibility": "decorative", "description": "Low-emphasis divider — decorative by definition" },
    { "id": "pm.color.border.strong", "type": "color", "required": false, "modeSensitive": true, "group": "color.border", "description": "High-emphasis border — informational; lint expects 3:1" },
    { "id": "pm.color.border.focus", "type": "color", "required": true, "modeSensitive": true, "group": "color.border", "description": "Focus-ring/active-field border — informational; lint expects 3:1" },

