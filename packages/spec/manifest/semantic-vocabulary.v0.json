{
  "contractVersion": "0.0.0",
  "dtcgBaseVersion": "2025.10",
  "namespace": "pm",
  "description": "Polymorph semantic vocabulary v0 (proposed). Canonical source of the contract's purpose-named tokens. Each entry: id, $type, required, modeSensitive, group, description. All ids are under the reserved 'pm' namespace.",
  "modes": { "default": "light", "supported": ["light", "dark", "highContrast"] },
  "tokens": [
    { "id": "pm.color.surface.base", "type": "color", "required": true, "modeSensitive": true, "group": "color.surface", "description": "Default app/page background" },
    { "id": "pm.color.surface.raised", "type": "color", "required": true, "modeSensitive": true, "group": "color.surface", "description": "Cards, sheets above base" },
    { "id": "pm.color.surface.sunken", "type": "color", "required": false, "modeSensitive": true, "group": "color.surface", "description": "Wells, insets below base" },
    { "id": "pm.color.surface.overlay", "type": "color", "required": false, "modeSensitive": true, "group": "color.surface", "description": "Modal/scrim surface" },
    { "id": "pm.color.surface.inverse", "type": "color", "required": false, "modeSensitive": true, "group": "color.surface", "description": "High-emphasis inverse surface" },
    { "id": "pm.color.text.body", "type": "color", "required": true, "modeSensitive": true, "group": "color.text", "description": "Default body text" },
    { "id": "pm.color.text.muted", "type": "color", "required": true, "modeSensitive": true, "group": "color.text", "description": "Secondary text" },
    { "id": "pm.color.text.subtle", "type": "color", "required": false, "modeSensitive": true, "group": "color.text", "description": "Tertiary/placeholder-adjacent text" },
    { "id": "pm.color.text.onAction", "type": "color", "required": true, "modeSensitive": true, "group": "color.text", "description": "Text/icon on a primary action fill" },
    { "id": "pm.color.text.onInverse", "type": "color", "required": false, "modeSensitive": true, "group": "color.text", "description": "Text on surface.inverse" },
    { "id": "pm.color.text.link", "type": "color", "required": true, "modeSensitive": true, "group": "color.text", "description": "Hyperlink/affordance text" },
    { "id": "pm.color.text.disabled", "type": "color", "required": true, "modeSensitive": true, "group": "color.text", "description": "Disabled text" },

    { "id": "pm.color.action.primary.rest", "type": "color", "required": true, "modeSensitive": true, "group": "color.action.primary", "description": "Primary action fill" },
    { "id": "pm.color.action.primary.hover", "type": "color", "required": false, "modeSensitive": true, "group": "color.action.primary", "description": "Primary hover (web)" },
    { "id": "pm.color.action.primary.pressed", "type": "color", "required": true, "modeSensitive": true, "group": "color.action.primary", "description": "Primary pressed/active" },
