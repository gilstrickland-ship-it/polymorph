{
  "name": "@polymorph/spec",
  "version": "0.0.0",
  "description": "Polymorph theme contract: DTCG-extended schema, semantic vocabulary, JSON Schema.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/*": "./schema/*",
    "./manifest/*": "./manifest/*"
  },
  "files": ["dist", "schema", "manifest"],
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  }
}
