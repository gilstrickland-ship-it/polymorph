{
  "name": "@polymorph/adapter-web-angular",
  "version": "0.0.0",
  "description": "Polymorph web adapter — Angular 18+ binding. Consumes the framework-agnostic core in @polymorph/adapter-web (CSS vars, ThemeBridge, slots, mapping, retrofit) and adds an Angular standalone ThemeProvider + inject() helpers.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@polymorph/spec": "workspace:*",
    "@polymorph/adapter-web": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=18",
    "rxjs": ">=7"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/common": "18.2.13",
    "@angular/compiler": "18.2.13",
    "@angular/core": "18.2.13",
    "@angular/platform-browser": "18.2.13",
    "@angular/platform-browser-dynamic": "18.2.13",
    "@polymorph/core": "workspace:*",
    "@types/node": "22.10.5",
    "happy-dom": "15.11.7",
    "rxjs": "7.8.1",
    "tslib": "2.8.1",
    "vitest": "2.1.8",
    "zone.js": "0.14.10"
  }
}
