{
  "name": "@polymorph/adapter-kotlin",
  "version": "0.0.0",
  "description": "Polymorph Kotlin adapter — build-time codegen from a Polymorph theme to a Kotlin `PolymorphTheme` object for Jetpack Compose (Color, Dp, TextStyle, CubicBezierEasing, shadows). No Android toolchain required to generate.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "update-goldens": "tsx scripts/update-goldens.ts"
  },
  "dependencies": {
    "@polymorph/spec": "workspace:*",
    "@polymorph/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gilstrickland-ship-it/polymorph.git",
    "directory": "packages/adapter-kotlin"
  },
  "homepage": "https://github.com/gilstrickland-ship-it/polymorph#readme",
  "bugs": {
    "url": "https://github.com/gilstrickland-ship-it/polymorph/issues"
  }
}
