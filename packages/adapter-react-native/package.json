{
  "name": "@polymorph/adapter-react-native",
  "version": "0.0.0",
  "description": "Polymorph React Native adapter: ThemeProvider, render slots, component-mapping registry.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@polymorph/spec": "workspace:*",
    "@polymorph/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@types/react": "18.3.12",
    "@types/react-test-renderer": "18.3.0",
    "react": "18.3.1",
    "react-test-renderer": "18.3.1",
    "vitest": "2.1.8"
  }
}
