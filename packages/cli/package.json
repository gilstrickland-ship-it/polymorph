{
  "name": "@polymorph/cli",
  "version": "0.0.0",
  "description": "Polymorph CLI: validate / lint / resolve / transform (Dart codegen via @polymorph/adapter-flutter; Swift codegen via @polymorph/adapter-swift; Kotlin codegen via @polymorph/adapter-kotlin).",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "polymorph": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@polymorph/spec": "workspace:*",
    "@polymorph/core": "workspace:*",
    "@polymorph/loaders": "workspace:*",
    "@polymorph/adapter-flutter": "workspace:*",
    "@polymorph/adapter-swift": "workspace:*",
    "@polymorph/adapter-kotlin": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "vitest": "2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gilstrickland-ship-it/polymorph.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/gilstrickland-ship-it/polymorph#readme",
  "bugs": {
    "url": "https://github.com/gilstrickland-ship-it/polymorph/issues"
  }
}
